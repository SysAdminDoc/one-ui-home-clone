# Copy to prototype-android/keystore.properties (gitignored) and fill in for local
# release builds. Gradle resolves this file via rootProject.file() which points at
# prototype-android/ (where settings.gradle.kts lives), NOT the repo root.
#
# CI builds pull these from repository secrets — see .github/workflows/release.yml.
storeFile=release.keystore
storePassword=CHANGE_ME
keyAlias=oneuihomeclone
keyPassword=CHANGE_ME
